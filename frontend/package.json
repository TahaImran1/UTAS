{
  "name": "utas-desktop",
  "version": "2.0.0",
  "description": "UTAS — Unified Time Attendance System Desktop App",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "electron": "electron .",
    "preview": "vite preview",
    "make-exe": "vite build && npx electron-packager . \"UTAS Desktop\" --platform=win32 --arch=x64 --out=dist-final --overwrite",
    "build-installer": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.utas.desktop",
    "productName": "UTAS Desktop",
    "publish": {
      "provider": "generic",
      "url": "https://YOUR_USERNAME.github.io/utas-updates/"
    },
    "directories": {
      "output": "dist-final"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "UTAS Desktop",
      "installerHeaderIcon": "./src/assets/icon.png",
      "include": "installer.nsh"
    },
    "extraResources": [
      {
        "from": "../backend/dist/UTAS.exe",
        "to": "UTAS.exe"
      },
      {
        "from": "../fk-bridge/FkBridge/bin/Release/net8.0/win-x86/publish/",
        "to": "fk-bridge/"
      },
      {
        "from": "../backend/.env.example",
        "to": ".env.default"
      }
    ]
  },
  "dependencies": {
    "axios": "^1.6.7",
    "date-fns": "^3.3.1",
    "electron-store": "^8.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.0.1",
    "react-router-dom": "^6.21.3",
    "recharts": "^2.10.3",
    "electron-updater": "^6.1.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.2.3",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "vite": "^5.0.12",
    "wait-on": "^7.2.0"
  }
}
