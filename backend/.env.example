# Oracle Database Configuration
ORACLE_HOST=your_oracle_host
ORACLE_PORT=1521
ORACLE_USER=your_oracle_user
ORACLE_PASSWORD=your_oracle_password
ORACLE_SERVICE_NAME=your_service_name

# Oracle Table Configuration
ORACLE_TABLE=your_table_name
ORACLE_COL_PK=your_pk_column
ORACLE_SEQ_PK=your_pk_sequence
ORACLE_COL_EMP=your_employee_column
ORACLE_COL_TIME=your_time_column
ORACLE_COL_MACHINE=your_machine_column

# Server Configuration
SERVER_PORT=4370
